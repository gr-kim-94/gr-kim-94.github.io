<div class="col">
  <div class="card project-card h-100">
    <div class="card-body project-card-body">
      <!-- 제목 -->
      <div class="project-title-row">
        {% if project.img %}
          <img class="project-title-img" src="{{ project.img | prepend: '/assets/img/' | relative_url }}" alt="">
        {% endif %}
        <h3 class="card-title project-title">{{ project.title }}</h3>
      </div>

      <!-- 기술 태그 -->
      {% assign desc_parts = project.description | split: ' · ' %}
      <div class="project-tech-tags">
        {% for part in desc_parts %}
          <span class="project-tech-tag">{{ part }}</span>
        {% endfor %}
      </div>

      <!-- 내용 구분선 -->
      <hr class="project-divider">

      <!-- 개발 목적 -->
      {% if project.purpose %}
        <div class="project-info-section">
          <span class="project-info-label">개발 목적</span>
          <p class="project-info-text">{{ project.purpose }}</p>
        </div>
      {% endif %}

      <!-- 주요 개발 -->
      {% if project.highlights %}
        <div class="project-info-section">
          <span class="project-info-label">주요 개발</span>
          <ul class="project-info-list">
            {% for item in project.highlights %}
              <li>{{ item }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      <!-- 성과 -->
      {% if project.outcomes %}
        <div class="project-info-section">
          <span class="project-info-label">성과</span>
          <ul class="project-info-list">
            {% for item in project.outcomes %}
              <li>{{ item }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      <!-- 기술 상세 링크 -->
      {% if project.github %}
        <a href="{{ project.github }}" class="project-icon-link" aria-label="GitHub">
          <i class="fa-brands fa-github"></i>
        </a>
      {% endif %}
    </div>
  </div>
</div>
